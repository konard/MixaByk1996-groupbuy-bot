{
  "compilerOptions": {
    "module": "commonjs",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "outDir": "./dist",
    "baseUrl": "../../",
    "paths": {
      "services/*": ["services/*"]
    },
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": false
  }
}
