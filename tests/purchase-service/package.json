{
  "name": "purchase-service-tests",
  "version": "1.0.0",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@nestjs/schedule": "^4.0.1",
    "@nestjs/typeorm": "^10.0.2",
    "reflect-metadata": "^0.2.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testRegex": ".*\\.test\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": ["ts-jest", {
        "tsconfig": "./tsconfig.json"
      }]
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^../../services/purchase-service/src/(.*)$": "<rootDir>/../../services/purchase-service/src/$1",
      "^typeorm$": "<rootDir>/node_modules/typeorm",
      "^@nestjs/common$": "<rootDir>/node_modules/@nestjs/common",
      "^@nestjs/common/(.*)$": "<rootDir>/node_modules/@nestjs/common/$1",
      "^@nestjs/core$": "<rootDir>/node_modules/@nestjs/core",
      "^@nestjs/core/(.*)$": "<rootDir>/node_modules/@nestjs/core/$1",
      "^@nestjs/typeorm$": "<rootDir>/node_modules/@nestjs/typeorm",
      "^@nestjs/typeorm/(.*)$": "<rootDir>/node_modules/@nestjs/typeorm/$1",
      "^@nestjs/schedule$": "<rootDir>/node_modules/@nestjs/schedule",
      "^@nestjs/schedule/(.*)$": "<rootDir>/node_modules/@nestjs/schedule/$1",
      "^@nestjs/testing$": "<rootDir>/node_modules/@nestjs/testing",
      "^@nestjs/testing/(.*)$": "<rootDir>/node_modules/@nestjs/testing/$1"
    }
  }
}
