# GroupBuy Bot Environment Configuration

# Docker image registry settings (for docker-compose.prod.yml)
# Images are built by CI and pushed to GitHub Container Registry automatically.
REGISTRY=ghcr.io
IMAGE_PREFIX=mixabyk1996/groupbuy-bot
# Tag to deploy: use 'main' for latest main branch, or a specific SHA/tag
IMAGE_TAG=main

# SSL / Domain (для продакшен-деплоя с Let's Encrypt)
DOMAIN=your-domain.com
CERTBOT_EMAIL=your@email.com

# Database
DB_NAME=groupbuy
DB_USER=postgres
DB_PASSWORD=your-secure-password

# Django
DJANGO_SECRET_KEY=your-django-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Telegram
TELEGRAM_TOKEN=your-telegram-bot-token

# Proxy for Telegram API (useful if api.telegram.org is blocked in your region)
# Option 1: Built-in SOCKS5 proxy (Docker container, no external proxy needed)
#   Set to true and start with: docker compose --profile proxy up -d
# TELEGRAM_USE_PROXY=true
#
# Option 2: External HTTP/SOCKS5 proxy (your own proxy server)
# TELEGRAM_PROXY_URL=socks5://user:pass@proxy-host:1080

# VK
VK_TOKEN=your-vk-group-access-token

# Tochka Bank (Cyclops) Payment Integration
# Cyclops - сервис номинальных счетов для онлайн-площадок
TOCHKA_API_URL=https://pre.tochka.com/api/v1/cyclops
# Для Production: https://api.tochka.com/api/v1/cyclops
TOCHKA_NOMINAL_ACCOUNT=your-nominal-account-number
TOCHKA_PLATFORM_ID=your-platform-id
TOCHKA_PRIVATE_KEY_PATH=/opt/groupbuy/keys/tochka_private.pem
TOCHKA_PUBLIC_KEY_PATH=/opt/groupbuy/keys/tochka_public.pem

# Legacy: YooKassa (если используется)
# YOOKASSA_SHOP_ID=your-shop-id
# YOOKASSA_SECRET_KEY=your-secret-key

# JWT Secret for WebSocket authentication
JWT_SECRET=your-jwt-secret-key

# Logging
LOG_LEVEL=INFO
