# GroupBuy Bot Environment Configuration

# Docker image registry settings (for docker-compose.prod.yml)
# Images are built by CI and pushed to GitHub Container Registry automatically.
REGISTRY=ghcr.io
IMAGE_PREFIX=mixabyk1996/groupbuy-bot
# Tag to deploy: use 'main' for latest main branch, or a specific SHA/tag
IMAGE_TAG=main

# SSL / Domain (для продакшен-деплоя с Let's Encrypt)
DOMAIN=your-domain.com
CERTBOT_EMAIL=your@email.com

# Database
DB_NAME=groupbuy
DB_USER=postgres
DB_PASSWORD=postgres

# Django
DJANGO_SECRET_KEY=your-django-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
# Server IP address — required when accessing Django admin via IP (no domain).
# Set to the public IP of your server so Django accepts requests to that host.
# Example: EXTERNAL_IP=95.81.123.52
EXTERNAL_IP=
# CORS: comma-separated list of allowed origins for Django CORS headers.
# Required when running without a domain (HTTP only / IP access).
# Examples:
#   No domain, access via IP:       CORS_ALLOWED_ORIGINS=http://192.168.1.100
#   Local dev with gateway on 3000: CORS_ALLOWED_ORIGINS=http://localhost:3000
#   With domain:                    CORS_ALLOWED_ORIGINS=https://your-domain.com
# Leave empty to allow no cross-origin requests (same-origin only).
CORS_ALLOWED_ORIGINS=
# Gunicorn workers for django-admin container (default: 2).
# Keep at 2 on memory-constrained hosts (≤4GB RAM) to avoid OOM.
GUNICORN_WORKERS=2

# Django admin superuser — created automatically on first container start.
# Leave DJANGO_SUPERUSER_PASSWORD empty to skip auto-creation and use
#   bash scripts/create-superuser.sh   instead.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me-in-production
DJANGO_SUPERUSER_EMAIL=admin@your-domain.com

# Telegram
TELEGRAM_TOKEN=your-telegram-bot-token

# Proxy for Telegram API (useful if api.telegram.org is blocked in your region)
# Option 1: Built-in SOCKS5 proxy (Docker container, no external proxy needed)
#   Set to true and start with: docker compose --profile proxy up -d
# TELEGRAM_USE_PROXY=true
#
# Option 2: External HTTP/SOCKS5 proxy (your own proxy server)
# TELEGRAM_PROXY_URL=socks5://user:pass@proxy-host:1080

# VK
VK_TOKEN=your-vk-group-access-token

# Mattermost
# Required: the token configured in Mattermost outgoing webhooks / slash commands
MATTERMOST_TOKEN=your-mattermost-outgoing-webhook-token
# Required: incoming webhook URL used to post messages back to Mattermost
MATTERMOST_WEBHOOK_URL=https://your-mattermost.com/hooks/your-incoming-webhook-id
# Required: public base URL of this Mattermost adapter service.
#   The Mattermost server uses this URL to:
#     - POST outgoing-webhook / slash-command payloads  →  <adapter>/webhook  or  <adapter>/slash
#     - POST interactive-button click payloads           →  <adapter>/mattermost_action
#   Within Docker on the same host: keep the default http://mattermost-adapter:8002
#   When Mattermost runs on a DIFFERENT server (separate from the bot server), set this
#   to the publicly reachable address of the machine running this adapter, e.g.:
#     MATTERMOST_ADAPTER_URL=http://<YOUR_BOT_SERVER_IP>:8002
#   Make sure port 8002 is open in your firewall / security group:
#     ufw allow 8002/tcp
MATTERMOST_ADAPTER_URL=http://mattermost-adapter:8002
# Required when Mattermost is on a separate server: base URL of the Mattermost server
# Used for REST API calls (DMs, user lookup, posting via API)
MATTERMOST_URL=https://your-mattermost.com
# Optional: bot-user personal-access token for REST API calls (DMs, user lookup)
# MATTERMOST_BOT_TOKEN=your-mattermost-bot-personal-access-token

# Tochka Bank (Cyclops) Payment Integration
# Cyclops - сервис номинальных счетов для онлайн-площадок
TOCHKA_API_URL=https://pre.tochka.com/api/v1/cyclops
# Для Production: https://api.tochka.com/api/v1/cyclops
TOCHKA_NOMINAL_ACCOUNT=your-nominal-account-number
TOCHKA_PLATFORM_ID=your-platform-id
TOCHKA_PRIVATE_KEY_PATH=/opt/groupbuy/keys/tochka_private.pem
TOCHKA_PUBLIC_KEY_PATH=/opt/groupbuy/keys/tochka_public.pem

# Legacy: YooKassa (если используется)
# YOOKASSA_SHOP_ID=your-shop-id
# YOOKASSA_SECRET_KEY=your-secret-key

# JWT Secret for WebSocket authentication
JWT_SECRET=your-jwt-secret-key
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key

# ─── Microservices v4.0 Configuration ─────────────────────────────────────

# Stripe Payment Integration
STRIPE_SECRET_KEY=sk_test_placeholder
# STRIPE_WEBHOOK_SECRET=whsec_...

# YooKassa Payment Integration
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key

# Telegram Bot (Notification Service)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-for-notifications

# WhatsApp Business API (Notification Service)
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# SMTP (Notification Service)
# For Yandex: SMTP_HOST=smtp.yandex.ru, SMTP_PORT=587, use an app password (not your account password).
# IMPORTANT for Yandex: the email address in SMTP_FROM must exactly match SMTP_USER.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=Groupbuy <notifications@example.com>

# VAPID Keys for Web Push (generate with web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# S3 / MinIO (Analytics & File Storage)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_password
S3_BUCKET=analytics-reports

# Elasticsearch (Search Service)
ELASTICSEARCH_URL=http://elasticsearch:9200

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=redis_secret

# Kafka
KAFKA_BROKERS=kafka:9092

# Rate Limiting
RATE_LIMIT_RPM=60
VOTING_RATE_LIMIT_RPM=120

# CORS Origins
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# Commission Settings (0-10%, step 0.5%)
MAX_COMMISSION_PERCENT=10

# Escrow Settings (in minor currency units, e.g., kopecks)
ESCROW_THRESHOLD=1000000
ESCROW_CONFIRMATION_PERCENT=80

# Logging
LOG_LEVEL=INFO
